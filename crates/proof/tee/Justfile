set positional-arguments

eif_describe_image := "base-prover-nitro-enclave-describe"
eif_output := "eif.bin"
tdx_verifier_guest := "base-proof-tee-tdx-attestation-prover-guest"

default:
    @just --list

# Run the nitro JSON-RPC server on the host
nitro-server *args:
    RUST_LOG=info \
        cargo run --package base-prover-nitro-host --bin base-prover-nitro-host -- server {{ args }}

# Run the nitro enclave (Linux only)
nitro-enclave *args:
    RUST_LOG=info \
        cargo run --package base-prover-nitro-enclave --bin base-prover-nitro-enclave {{ args }}

# Run server and enclave in a single process for local development
nitro-local *args:
    RUST_LOG=info RUST_BACKTRACE=1 \
        cargo run --package base-prover-nitro-host --bin base-prover-nitro-host --features local -- local \
        --l1-eth-url "${L1_ETH_URL:-http://localhost:8545}" \
        --l2-eth-url "${L2_ETH_URL:-http://localhost:9545}" \
        --l1-beacon-url "${L1_BEACON_URL:-http://localhost:5052}" \
        --l2-chain-id "${L2_CHAIN_ID:-8453}" \
        --listen-addr "${LISTEN_ADDR:-0.0.0.0:8000}" \
        --enable-experimental-witness-endpoint \
        --metrics.enabled \
        --logs.stdout.format json \
        {{ args }}

# Print config hashes for all supported chains
config-hashes:
    cargo test -p base-enclave print_real_config_hashes -- --nocapture --ignored

# Get the enclave signer's Ethereum address from a remote prover
signer-address url:
    #!/usr/bin/env bash
    set -euo pipefail
    command -v cast >/dev/null 2>&1 || { echo "error: 'cast' (foundry) is required. Install: https://book.getfoundry.sh/getting-started/installation" >&2; exit 1; }
    command -v python3 >/dev/null 2>&1 || { echo "error: 'python3' is required" >&2; exit 1; }

    PUB_KEY_HEX=$(cast rpc enclave_signerPublicKey -r "{{ url }}" \
        | python3 -c "import json, sys; data = json.load(sys.stdin)[0]; print('0x' + bytes(data[1:]).hex())")

    HASH=$(cast keccak "$PUB_KEY_HEX")
    ADDR=$(cast to-check-sum-address "0x${HASH: -40}")
    echo "Signer address: $ADDR"

# Get PCR0 and teeImageHash from a remote prover's attestation document
remote-pcr0 url:
    #!/usr/bin/env bash
    set -euo pipefail
    command -v cast >/dev/null 2>&1 || { echo "error: 'cast' (foundry) is required. Install: https://book.getfoundry.sh/getting-started/installation" >&2; exit 1; }
    command -v python3 >/dev/null 2>&1 || { echo "error: 'python3' is required" >&2; exit 1; }
    python3 -c "import cbor2" 2>/dev/null || {
        echo "error: python3 'cbor2' package is required (install with: pip3 install cbor2)" >&2
        exit 1
    }

    PCR0=$(cast rpc enclave_signerAttestation -r "{{ url }}" \
        | python3 -c "import cbor2,json,sys; data=bytes(json.load(sys.stdin)[0]); _,_,payload,_=cbor2.loads(data); doc=cbor2.loads(payload); print(doc['pcrs'][0].hex())")

    TEE_IMAGE_HASH=$(cast keccak "0x$PCR0")
    echo "PCR0:         $PCR0"
    echo "teeImageHash: $TEE_IMAGE_HASH"

# Build EIF and extract it (via --target describe)
build-eif *args="":
    #!/usr/bin/env bash
    set -euo pipefail
    cd ../../..
    DOCKER_BUILDKIT=1 docker build --platform linux/amd64 {{ args }} -f etc/docker/Dockerfile.nitro-enclave --target describe -t {{ eif_describe_image }} .
    docker rm -f eif-extract 2>/dev/null || true
    docker create --name eif-extract {{ eif_describe_image }}
    docker cp eif-extract:/app/eif.bin crates/proof/tee/{{ eif_output }}
    docker rm eif-extract
    echo "EIF built successfully: crates/proof/tee/{{ eif_output }}"
    ls -lh crates/proof/tee/{{ eif_output }}

# Show PCR values for the current EIF image
describe-eif:
    @echo "PCR values for {{ eif_describe_image }}:"
    @just _describe-eif {{ eif_describe_image }}

# Build the TDX verifier guest and print its RISC Zero image ID
tdx-verifier-image-id:
    #!/usr/bin/env bash
    set -euo pipefail

    tee_dir="$(cd "$(dirname "{{ source_file() }}")" && pwd)"
    guest_dir="$tee_dir/tdx-attestation-prover/guest"
    helper_manifest="$tee_dir/nitro-attestation-prover/guest/tools/compute-image-id/Cargo.toml"
    elf_path="$guest_dir/target/riscv32im-risc0-zkvm-elf/release/{{ tdx_verifier_guest }}"
    r0bf_path="$guest_dir/target/{{ tdx_verifier_guest }}.r0bf"

    command -v cargo >/dev/null 2>&1 || { echo "error: 'cargo' is required" >&2; exit 1; }
    command -v rustup >/dev/null 2>&1 || { echo "error: 'rustup' is required" >&2; exit 1; }
    if ! rustup toolchain list | grep -q '^risc0'; then
        echo "error: RISC Zero rust toolchain 'risc0' is not installed (install with: rzup install)" >&2
        exit 1
    fi

    echo "Building TDX verifier guest ELF..."
    (
        cd "$guest_dir"
        cargo +risc0 build --release --target riscv32im-risc0-zkvm-elf --ignore-rust-version
    )

    echo "Bundling ELF into R0BF and computing image ID..."
    output=$(
        RISC0_SKIP_BUILD_KERNELS=1 cargo run --quiet \
            --manifest-path "$helper_manifest" -- \
            "$elf_path" \
            --output "$r0bf_path"
    )
    echo "$output"

    actual=$(printf '%s\n' "$output" | sed -n 's/^Image ID: //p' | tail -n1)
    if [ -z "$actual" ]; then
        echo "error: failed to parse image ID from helper output" >&2
        exit 1
    fi

    echo "image ID: 0x$actual"
    echo "R0BF: $r0bf_path"

# Inspect a TDX prover's signer and contract-compatible image hash
tdx-image-hash endpoint="http://136.107.166.21:7310" *args="":
    cargo run -q -p base-proof-tee-tdx-image-hash -- --endpoint "{{ endpoint }}" --verify-quote {{ args }}

# Build twice and compare to verify reproducibility
verify-reproducible:
    #!/usr/bin/env bash
    set -euo pipefail
    cleanup() {
        rm -f eif-first.bin eif-second.bin
        just _clean-eif-images
    }
    trap cleanup EXIT

    echo "=== Building EIF (first) ==="
    just build-eif
    docker tag {{ eif_describe_image }} {{ eif_describe_image }}:first
    mv "{{ eif_output }}" eif-first.bin

    echo ""
    echo "=== Building EIF (second, --no-cache) ==="
    just build-eif --no-cache
    docker tag {{ eif_describe_image }} {{ eif_describe_image }}:second
    mv "{{ eif_output }}" eif-second.bin

    echo ""
    echo "=== Comparing sha256 hashes ==="
    HASH1=$(just sha256 eif-first.bin)
    HASH2=$(just sha256 eif-second.bin)
    echo "First:  $HASH1"
    echo "Second: $HASH2"
    if [ "$HASH1" != "$HASH2" ]; then
        echo "FAILURE: SHA256 hashes differ — build is NOT reproducible"
        exit 1
    fi
    echo "SHA256: MATCH"

    echo ""
    echo "=== Comparing PCR0 values ==="
    PCR0_FIRST=$(just pcr0 {{ eif_describe_image }}:first)
    PCR0_SECOND=$(just pcr0 {{ eif_describe_image }}:second)
    echo "First:  $PCR0_FIRST"
    echo "Second: $PCR0_SECOND"
    if [ "$PCR0_FIRST" != "$PCR0_SECOND" ]; then
        echo "FAILURE: PCR0 values differ — build is NOT reproducible"
        exit 1
    fi
    echo "PCR0: MATCH"

    echo ""
    echo "SUCCESS: Build is reproducible!"
    echo "  SHA256: $HASH1"
    echo "  PCR0:   $PCR0_FIRST"

# Clean EIF artifacts
clean-eif:
    rm -f "{{ eif_output }}" eif-first.bin eif-second.bin
    @just _clean-eif-images
    @echo "EIF artifacts cleaned"

# --- Private helpers ---

[private]
_clean-eif-images:
    -@docker rmi {{ eif_describe_image }} {{ eif_describe_image }}:first {{ eif_describe_image }}:second 2>/dev/null

[private]
_describe-eif image:
    @docker run --rm --platform linux/amd64 {{ image }} \
        ./nitro-cli describe-eif --eif-path eif.bin

[private]
sha256 file:
    #!/usr/bin/env bash
    set -euo pipefail
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "{{ file }}" | cut -d' ' -f1
    else
        shasum -a 256 "{{ file }}" | cut -d' ' -f1
    fi

[private]
pcr0 image:
    #!/usr/bin/env bash
    set -euo pipefail
    just _describe-eif {{ image }} | grep -o '"PCR0": "[^"]*"' | cut -d'"' -f4
